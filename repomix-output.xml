  /* ── Two-column layout ── */
  .cp-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 20px;
    align-items: start;
  }
  .cp-right-col {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* ── Card ── */
  .cp-card {
    background: var(--surface);
    border: 1px solid var(--border);
