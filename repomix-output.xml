  }
  .hp-floating-sub {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: var(--faint);
    margin: 4px 0 0;
  }
  .hp-tag {
    background: var(--violet-lt);
    color: var(--violet);
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 100px;
    flex-shrink: 0;
  }
  .hp-count {
    font-size: 12px;
    font-weight: 600;
    color: var(--violet);
    flex-shrink: 0;
  }

  /* Page body */
  .hp-page-body {
    max-width: 1100px;
    margin: 0 auto;
    padding: 64px 24px;
    display: flex;
    flex-direction: column;
    gap: 28px;
