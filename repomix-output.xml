  .hp-section-title {
    font-size: 28px;
    font-weight: 700;
    text-align: center;
    margin: 0 0 28px;
  }

  /* Feature grid */
  .hp-feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
