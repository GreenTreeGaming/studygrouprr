  /* ── CTA card ── */
  .cp-cta-card { }
  .cp-cta-eyebrow {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--violet-mid);
