  .cp-stat-icon--accent { color: var(--violet); }
  .cp-stat-value {
    font-size: 28px;
    font-weight: 700;
    line-height: 1;
    margin: 0 0 2px;
  }
  .cp-stat-value--accent { color: var(--violet); }
  .cp-stat-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
