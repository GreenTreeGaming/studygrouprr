    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }
  .card-title {
    font-size: 18px;
    font-weight: 700;
    margin: 0;
  }
  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    font-size: 13px;
    font-weight: 500;
    color: var(--violet);
    text-decoration: none;
  }
  .card-link:hover { text-decoration: underline; }

  /* ── Empty state ── */
  .empty-state {
    text-align: center;
    padding: 40px 24px;
    border: 2px dashed var(--border);
    border-radius: 16px;
  }
  .empty-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--violet-mid);
    margin-bottom: 12px;
  }
  .empty-heading {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 6px;
